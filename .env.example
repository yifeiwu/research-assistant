# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Exa API key — https://dashboard.exa.ai/api-keys
EXA_API_KEY=your_exa_api_key_here

# Optional: override the default Groq model (must support tool calling)
# GROQ_MODEL=qwen/qwen3.6-27b

# Optional: cheap/fast Groq model used to summarize each web page (map step)
# GROQ_SUMMARY_MODEL=llama-3.1-8b-instant

# Optional: set to 1 to enable verbose per-step server logs (tool calls, usage,
# summarization). Errors (incl. Groq failed_generation) are always logged.
# DEBUG_AGENT=1
